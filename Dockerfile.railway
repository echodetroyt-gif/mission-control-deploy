FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --production

# Copy app code
COPY . .

# Build the app
RUN npm run build

# Create workspace directory
RUN mkdir -p /app/workspace/projects

# Expose port
EXPOSE 4000

# Start command
CMD ["npm", "run", "start"]
